# คัดลอกไฟล์นี้เป็น .env.local (Next.js จะโหลดให้อัตโนมัติ) แล้วเติมค่าจริง
# หมายเหตุ: ระบบรันได้ทันทีแบบ "โหมดตัวอย่าง" โดยไม่ต้องตั้งค่าใด ๆ (อ่าน mock data)
#          จะใช้ข้อมูลจริงเมื่อกรอก Supabase + BigQuery + Anthropic ครบ

# ── Supabase (ชั้นพักข้อมูล) ─────────────────────────────
# เอาจาก Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...        # service_role key (ฝั่ง server เท่านั้น ห้ามเปิดเผย)

# ── BigQuery (ต้นทางคอมเมนต์) ────────────────────────────
# path ไปยังไฟล์ service account JSON (สิทธิ์ BigQuery Data Viewer + Job User)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# override ค่า default ใน src/lib/config.ts ได้ (ถ้าไม่ตั้ง จะใช้ค่าในไฟล์)
# BQ_PROJECT_ID=elated-channel-468406-t4
# BQ_DATASET=Platform
# BQ_TABLE=shopee_product_comments
# BQ_LOCATION=US

# ── Anthropic (วิเคราะห์ด้วย Claude) ─────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# AI_MODEL=claude-sonnet-4-6
# AI_ENABLED=false        # ตั้ง false เพื่อใช้ rule-based อย่างเดียว (ฟรี ไม่เรียก AI)

# ── Pipeline ─────────────────────────────────────────────
# WINDOW_DAYS=30          # หน้าต่างเวลาที่ dashboard สรุป
# INITIAL_BACKFILL_DAYS=30
# MAX_PER_RUN=0           # จำกัดจำนวนต่อรอบ (0 = ไม่จำกัด)

# secret ป้องกัน endpoint /api/pipeline (ตั้งตอน deploy เพื่อให้ cron ภายนอกยิงได้)
# PIPELINE_SECRET=ใส่ค่าสุ่มยาว ๆ
